{
  "name": "@jaiew/result",
  "version": "0.0.1",
  "description": "A type-safe Result pattern implementation for explicit success and error state handling.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run format:check && npm run lint && npm run build && npm run test:coverage"
  },
  "keywords": [
    "result",
    "either",
    "monad",
    "type-safe",
    "error-handling",
    "typescript"
  ],
  "contributors": [
    {
      "name": "Jaie Wilson",
      "email": "me@jaiewilson.com"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/result-lib.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/result-lib/issues"
  },
  "homepage": "https://github.com/your-username/result-lib#readme",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true
  }
}
